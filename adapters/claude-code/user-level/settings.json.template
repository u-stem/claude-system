{
  "//": "Claude Code user-level settings template. Phase 10 で ~/.claude/settings.json として配置される(symlink ではなく cp による配置を推奨。マシン固有値の差し込みのため)。'//' で始まるキーは Claude Code 側で無視されるため JSON コメント代替として使用",

  "// env": "サブプロセスへ機密 env を漏らさない、autocompact 閾値、1h prompt cache 等。EXPERIMENTAL_AGENT_TEAMS は Opus 4.7 期に厳格化(3 PBI 以上 + 完全独立ファイルのみ適用)した上で有効維持",
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },

  "respectGitignore": true,
  "language": "japanese",
  "model": "claude-opus-4-7",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "sandbox": {
    "failIfUnavailable": true
  },

  "// permissions": "deny は物理ブロック(LLM の自制に頼らない)。allow は良性で頻出するコマンドを列挙して permission prompt を抑制する。両者の整合は Phase 7b で再点検する",
  "// permissions.deny.protected_paths": "旧 claude-settings はアーカイブで読み取り専用。Phase 10 で symlink 切替するまで現運用を維持するため write を物理ブロック",
  "// permissions.deny.backup_files": "*.backup-* は人間が手作業バックアップした原本。LLM が上書きしないよう物理ブロック",
  "// permissions.deny.destructive_filesystem": "~/.claude/ や claude-system 全体の rm を物理ブロック。Phase 10 のシンボリックリンク切替を保護する。-rf 以外の派生(-r 単独 / sudo / find -delete)も列挙",
  "// permissions.deny.destructive_git": "強制 push と --no-verify は禁止。--no-verify は Phase 7b の PreToolUse hook(jq インライン)でも検出予定の二重防御",
  "// permissions.deny.secrets": "機密ファイル系の Read/Write/Edit を全面ブロック。Phase 7b で .gitleaks.toml と整合させる。相対パス glob が中心のため絶対パス・~ 展開後のアクセスは hooks 側(pre-edit-protect.sh / pre-bash-guard.sh)で補完する",
  "// permissions.deny.global_secrets": "ホームディレクトリ直下の標準的機密保管箇所を deny。.ssh / .aws / .gnupg / .config の認証系は内容にかかわらず Read を物理ブロック",
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Edit(~/ws/claude-settings/**)",
      "Write(~/ws/claude-settings/**)",
      "Edit(**/*.backup-*)",
      "Write(**/*.backup-*)",
      "Bash(rm -rf ~/.claude*)",
      "Bash(rm -r ~/.claude*)",
      "Bash(rm -rf ~/ws/claude-system)",
      "Bash(rm -r ~/ws/claude-system)",
      "Bash(rm -rf ~/ws/claude-system/*)",
      "Bash(sudo rm *)",
      "Bash(find ~/.claude*)",
      "Bash(find ~/ws/claude-system*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git commit*--no-verify*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials*)",
      "Read(./**/*secret*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.cargo/credentials*)",
      "Read(~/.docker/config.json)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)"
    ],
    "// permissions.allow.package_managers": "bun > pnpm > npm の優先順は user-level/CLAUDE.md 記載と整合。uv は Python 用",
    "// permissions.allow.compilers": "cargo / go / python3 / node / deno",
    "// permissions.allow.git": "git は deny 側で強制 push と --no-verify をブロック済みのため allow 側はワイルドカードで良い",
    "// permissions.allow.shell_basics": "読み取り系・移動系・展開系。意図しない副作用は deny 側で個別ブロック",
    "// permissions.allow.file_ops": "削除系(rm 等)は意図的に allow に入れない。都度 ask で十分",
    "// permissions.allow.network": "取得系のみ。送信系の curl -X POST 等は都度 ask",
    "// permissions.allow.docker": "観察系のみ allow。run / build / push 系は ask",
    "// permissions.allow.audit_tools": "security-auditor subagent / dependency-review skill / supply-chain-hygiene practice で利用する読み取り系監査コマンド。bun audit / npm audit / uv pip audit は package manager のワイルドカードで covered、gitleaks のみ独立 allow が必要",
    "allow": [
      "Bash(bun *)",
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npm install)",
      "Bash(npm add *)",
      "Bash(npm uninstall *)",
      "Bash(npm ls *)",
      "Bash(npm info *)",
      "Bash(npm outdated *)",
      "Bash(npm audit *)",
      "Bash(uv *)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(goimports *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(deno *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(bash *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(jq *)",
      "Bash(xargs *)",
      "Bash(diff *)",
      "Bash(comm *)",
      "Bash(uname *)",
      "Bash(printenv *)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker ps *)",
      "Bash(docker ps)",
      "Bash(docker images *)",
      "Bash(docker images)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)",
      "Bash(docker compose *)",
      "Bash(claude *)",
      "Bash(gitleaks detect *)",
      "Bash(gitleaks version)",
      "Bash(gitleaks version *)",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ]
  },

  "// hooks": "Phase 7b で結線。本物の実体は adapters/claude-code/user-level/hooks/*.sh。Phase 10 で ~/.claude/hooks/ に symlink される。緊急停止は tools/disable-guardrails.sh を使う",
  "// hooks.SessionStart": "繰り返し失敗パターンを通知して self-improving loop を促す",
  "// hooks.PreToolUse.Bash": "破壊的コマンド阻止 + 若いパッケージ阻止(supply-chain)。各 hook は対象外コマンドで早期 exit する",
  "// hooks.PreToolUse.Edit_Write": "claude-settings/ や *.backup-* への書き込み阻止 + principles/practices への禁止語混入阻止",
  "// hooks.PostToolUse.Edit_Write": "validate(SKILL.md frontmatter / 禁止語) + project dispatcher(.claude/hooks/post-edit.sh)",
  "// hooks.PostToolUse.Bash": "Bash 失敗を category 判定して failure-log.jsonl に追記(self-referential feedback loop)",
  "// hooks.Stop": "stop diagnostic(timeout 付き doctor.sh)+ project dispatcher(.claude/hooks/post-stop.sh)",
  "// hooks.SubagentStop": "基本ログ + ADR 0001/0002 サニタイゼーション + tools 越権検知(log-only、Phase 9 で escalation 再評価)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/check-failure-patterns.sh"}
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/pre-bash-guard.sh"},
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/check-package-age.sh"}
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/pre-edit-protect.sh"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/post-edit-validate.sh"},
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/post-edit-dispatcher.sh"}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/log-bash-failure.sh"}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/stop-session-doctor.sh"},
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/post-stop-dispatcher.sh"}
        ]
      }
    ],
    "StopFailure": [],
    "SubagentStop": [
      {
        "hooks": [
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/subagent-stop-record.sh"},
          {"type": "command", "command": "$HOME/ws/claude-system/adapters/claude-code/user-level/hooks/subagent-stop-audit.sh"}
        ]
      }
    ],
    "PreCompact": [],
    "SessionEnd": []
  },

  "// enabledPlugins": "superpowers / elements-of-style / episodic-memory は新システムでも継続採用。Memory MCP は不採用(ADR 0003 で確定済み)",
  "enabledPlugins": {
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true
  },

  "// mcpServers": "API キーを要しない MCP のみテンプレートに含める。github / その他キー必須の MCP は配置時に手動で追加し、本テンプレートには含めない(secrets-handling 原則)",
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@0.20.3"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.70"]
    }
  }
}
