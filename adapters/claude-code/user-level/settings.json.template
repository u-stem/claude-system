{
  "//": "Claude Code user-level settings template. Phase 10 で ~/.claude/settings.json として配置される(symlink ではなく cp による配置を推奨。マシン固有値の差し込みのため)。'//' で始まるキーは Claude Code 側で無視されるため JSON コメント代替として使用",

  "// env": "サブプロセスへ機密 env を漏らさない、autocompact 閾値、1h prompt cache 等。EXPERIMENTAL_AGENT_TEAMS は Opus 4.7 期に厳格化(3 PBI 以上 + 完全独立ファイルのみ適用)した上で有効維持",
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },

  "respectGitignore": true,
  "language": "japanese",
  "model": "claude-opus-4-7",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "sandbox": {
    "failIfUnavailable": true
  },

  "// permissions": "deny は物理ブロック(LLM の自制に頼らない)。allow は良性で頻出するコマンドを列挙して permission prompt を抑制する。両者の整合は Phase 7b で再点検する",
  "// permissions.deny.protected_paths": "旧 claude-settings はアーカイブで読み取り専用。Phase 10 で symlink 切替するまで現運用を維持するため write を物理ブロック",
  "// permissions.deny.backup_files": "*.backup-* は人間が手作業バックアップした原本。LLM が上書きしないよう物理ブロック",
  "// permissions.deny.destructive_filesystem": "~/.claude/ や claude-system 全体の rm -rf を物理ブロック。Phase 10 のシンボリックリンク切替を保護する",
  "// permissions.deny.destructive_git": "強制 push と --no-verify は禁止。--no-verify は Phase 7b の PreToolUse hook(jq インライン)でも検出予定の二重防御",
  "// permissions.deny.secrets": "機密ファイル系の Read/Write/Edit を全面ブロック。Phase 7b で .gitleaks.toml と整合させる",
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Edit(~/ws/claude-settings/**)",
      "Write(~/ws/claude-settings/**)",
      "Edit(**/*.backup-*)",
      "Write(**/*.backup-*)",
      "Bash(rm -rf ~/.claude*)",
      "Bash(rm -rf ~/ws/claude-system)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git commit*--no-verify*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials*)",
      "Read(./**/*secret*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)"
    ],
    "// permissions.allow.package_managers": "bun > pnpm > npm の優先順は user-level/CLAUDE.md 記載と整合。uv は Python 用",
    "// permissions.allow.compilers": "cargo / go / python3 / node / deno",
    "// permissions.allow.git": "git は deny 側で強制 push と --no-verify をブロック済みのため allow 側はワイルドカードで良い",
    "// permissions.allow.shell_basics": "読み取り系・移動系・展開系。意図しない副作用は deny 側で個別ブロック",
    "// permissions.allow.file_ops": "削除系(rm 等)は意図的に allow に入れない。都度 ask で十分",
    "// permissions.allow.network": "取得系のみ。送信系の curl -X POST 等は都度 ask",
    "// permissions.allow.docker": "観察系のみ allow。run / build / push 系は ask",
    "allow": [
      "Bash(bun *)",
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npm install)",
      "Bash(npm add *)",
      "Bash(npm uninstall *)",
      "Bash(npm ls *)",
      "Bash(npm info *)",
      "Bash(npm outdated *)",
      "Bash(npm audit *)",
      "Bash(uv *)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(goimports *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(deno *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(bash *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(jq *)",
      "Bash(xargs *)",
      "Bash(diff *)",
      "Bash(comm *)",
      "Bash(uname *)",
      "Bash(printenv *)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker ps *)",
      "Bash(docker ps)",
      "Bash(docker images *)",
      "Bash(docker images)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)",
      "Bash(docker compose *)",
      "Bash(claude *)",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch"
    ]
  },

  "// hooks": "ここは Phase 7b で本格実装される。本テンプレートでは枠と TODO のみ。詳細は meta/TODO-for-phase-7b.md および adapters/claude-code/user-level/hooks/_README.md 参照",
  "// hooks.SessionStart": "TODO(Phase 7b): check-failure-patterns.sh を結線(失敗フィードバックループの起点)",
  "// hooks.PreToolUse": "TODO(Phase 7b): check-package-age.sh / filter-test-output.sh / require-review-before-commit.sh / --no-verify+破壊的 git 検出を結線",
  "// hooks.PostToolUse": "TODO(Phase 7b): post-edit dispatcher(プロジェクト側 .claude/hooks/post-edit.sh への委譲)、log-bash-failure、lockfile 変更通知を結線",
  "// hooks.Stop": "TODO(Phase 7b): post-stop dispatcher(プロジェクト側 .claude/hooks/post-stop.sh)を結線",
  "hooks": {
    "SessionStart": [],
    "PreToolUse": [],
    "PostToolUse": [],
    "Stop": [],
    "StopFailure": [],
    "SubagentStop": [],
    "PreCompact": [],
    "SessionEnd": []
  },

  "// enabledPlugins": "superpowers / elements-of-style / episodic-memory は新システムでも継続採用。Memory MCP は不採用(Phase 4 の memory-architecture ADR で確定予定)",
  "enabledPlugins": {
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true
  },

  "// mcpServers": "API キーを要しない MCP のみテンプレートに含める。github / その他キー必須の MCP は配置時に手動で追加し、本テンプレートには含めない(secrets-handling 原則)",
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@0.20.3"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.70"]
    }
  }
}
